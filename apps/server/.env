# Server configuration
PORT=3000
BASE_URL=http://localhost:3000

# Security
API_KEY=test-api-key-1234

# Database
# REDIS_URL=redis://localhost:6379 (commented out as Redis is optional for development)

# Environment
NODE_ENV=development

# Token configuration
